amends "package://github.com/jdx/hk/releases/download/v1.41.0/hk@1.41.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.41.0/hk@1.41.0#/Builtins.pkl"

exclude = List("internal/api/docs")

local linters = new Mapping<String, Step> {
    ["trailing-whitespace"] = Builtins.trailing_whitespace
    ["end-of-file-fixer"] = Builtins.newlines
    ["check-added-large-files"] = Builtins.check_added_large_files
    ["check-case-conflict"] = Builtins.check_case_conflict
    ["check-merge-conflict"] = Builtins.check_merge_conflict
    ["fix-smart-quotes"] = Builtins.fix_smart_quotes

    ["zizmor"] = Builtins.zizmor
    ["mise"] = Builtins.mise
    ["hadolint"] = (Builtins.hadolint) {
        glob = List("**/Dockerfile*","**/Containerfile*")
    }

    ["go-mod-tidy"] = Builtins.gomod_tidy
    ["golangci-lint"] = Builtins.golangci_lint
    ["golangci-lint-config-verify"] {
        workspace_indicator = ".golangci.yml"
        check = "cd {{workspace}} && golangci-lint config verify"
    }
    ["go-generate"] {
        fix = "go generate ./..."
    }

    ["just-format"] {
        glob = List("**/justfile")
        check = "for f in {{ files }}; do just --fmt --check --unstable --justfile ${f}; done"
        fix = "for f in {{ files }}; do just --fmt --unstable --justfile ${f}; done"
    }
    ["swag-fmt"] {
        glob = List("**/*.go")
        fix = "swag fmt {{ files }}"
    }
    ["swag-init"] {
        //glob = List("**/*.go")
        fix = "swag init --parseDependency --parseInternal --parseDepth=1 --dir=./internal/api/handlers --generalInfo=./root.go --output=./internal/api/docs"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }

    ["commit-msg"] {
        steps {
            ["check-conventional-commit"] = Builtins.check_conventional_commit
        }
    }

    ["fix"] {
        fix = true
        steps = linters
    }

    ["check"] {
        steps = linters
    }
}
